parameters:
    level: 9
    treatPhpDocTypesAsCertain: false
    paths:
        - packages/objectquel/src
        - packages/canvas-objectquel
        - packages/canvas/src
        - packages/annotation-reader/src
        - packages/discover/src
        - packages/signal-hub/src

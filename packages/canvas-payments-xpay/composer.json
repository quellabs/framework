{
  "name": "quellabs/canvas-payments-xpay",
  "description": "Nexi XPay Global payment gateway integration for the Canvas PHP framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "info@quellabs.com"
    }
  ],
  "keywords": [
    "xpay",
    "nexi",
    "payments",
    "payment gateway",
    "canvas",
    "canvas-payments",
    "europe"
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas-payments-xpay/issues",
    "forum": "https://github.com/quellabs/canvas-payments-xpay/discussions",
    "wiki": "https://github.com/quellabs/canvas-payments-xpay/wiki",
    "docs": "https://canvasphp.com/docs",
    "source": "https://github.com/quellabs/canvas-payments-xpay"
  },
  "require": {
    "php": "^8.3",
    "symfony/http-client": "^7.0 || ^8.0",
    "quellabs/support": "*",
    "quellabs/contracts": "*",
    "quellabs/canvas-payments-contracts": "*"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Payments\\XPay\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "canvas": {
        "controller": "Quellabs\\Payments\\XPay\\XPayController"
      },
      "sculpt": {
        "provider": "Quellabs\\Payments\\XPay\\ServiceProvider"
      },
      "payments": {
        "provider": "Quellabs\\Payments\\XPay\\Driver",
        "config": "config/xpay.php"
      }
    }
  }
}
{
  "name": "quellabs/canvas",
  "description": "A modern, lightweight PHP framework with contextual containers, automatic service discovery, and ObjectQuel ORM integration",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "floris@quellabs.com"
    }
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas/issues",
    "forum": "https://github.com/quellabs/canvas/discussions",
    "wiki": "https://github.com/quellabs/canvas/wiki",
    "docs": "https://canvasphp.com/docs",
    "source": "https://github.com/quellabs/canvas"
  },
  "keywords": [
    "framework",
    "contextual-containers",
    "dependency-injection",
    "templating"
  ],
  "type": "library",
  "license": "MIT",
  "config": {
    "platform": {
      "php": "8.4"
    },
    "allow-plugins": {
      "quellabs/discover": false
    }
  },
  "require": {
    "php": ">=8.4",
    "monolog/monolog": "^3.10",
    "symfony/http-foundation": "^8.0",
    "dragonmantank/cron-expression": "^3.6",
    "quellabs/contracts": "^1",
    "quellabs/support": "^1",
    "quellabs/discover": "^1",
    "quellabs/dependency-injection": "^1",
    "quellabs/sculpt": "^1",
    "quellabs/signal-hub": "^1",
    "quellabs/canvas-smarty": "^1",
    "quellabs/annotation-reader": "^1"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Canvas\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "sculpt": {
        "provider": "Quellabs\\Canvas\\Sculpt\\CanvasProvider",
        "config": "config/app.php"
      },
      "task-scheduler": {
        "provider": "Quellabs\\Canvas\\Tasks\\Task"
      }
    }
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/quellabs"
    }
  ]
}
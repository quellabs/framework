{
  "name": "quellabs/canvas-loom",
  "description": "Definition-driven page builder for Canvas that turns PHP builder definitions into data-bound admin interfaces.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://canvasphp.com",
  "keywords": ["admin", "loom", "canvas", "wakapac", "form-builder", "admin-panel", "php"],
  "authors": [
    {
      "name": "Floris",
      "email": "floris@quellabs.com",
      "homepage": "https://canvasphp.com",
      "role": "Developer"
    }
  ],
  "support": {
    "email": "floris@quellabs.com",
    "source": "https://canvasphp.com"
  },
  "require": {
    "php": ">=8.3",
    "quellabs/support": "*",
    "quellabs/contracts": "^1.0",
    "quellabs/sculpt": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Canvas\\Loom\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Quellabs\\Canvas\\Loom\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "discover": {
      "sculpt": {
        "provider": "Quellabs\\Canvas\\Loom\\Sculpt\\ServiceProvider",
        "config": "config/app.php"
      }
    }
  }
}
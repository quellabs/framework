{
  "name": "quellabs/canvas-payments-adyen",
  "description": "Adyen payment gateway integration for the Canvas PHP framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "info@quellabs.com"
    }
  ],
  "keywords": [
    "adyen",
    "payments",
    "payment gateway",
    "canvas",
    "canvas-payments"
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas-payments-adyen/issues",
    "forum": "https://github.com/quellabs/canvas-payments-adyen/discussions",
    "wiki": "https://github.com/quellabs/canvas-payments-adyen/wiki",
    "docs": "https://canvasphp.php/docs",
    "source": "https://github.com/quellabs/canvas-payments-adyen"
  },
  "require": {
    "php": "^8.2",
    "symfony/http-client": "^7.0 || ^8.0",
    "quellabs/support": "*",
    "quellabs/contracts": "*",
    "quellabs/canvas-payments-contracts": "*"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Payments\\Adyen\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "canvas": {
        "controller": "Quellabs\\Payments\\Adyen\\AdyenController"
      },
      "sculpt": {
        "provider": "Quellabs\\Payments\\Adyen\\Sculpt\\ServiceProvider"
      },
      "payments": {
        "provider": "Quellabs\\Payments\\Adyen\\Driver",
        "config": "config/adyen.php"
      }
    }
  }
}
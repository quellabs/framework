{
  "name": "quellabs/canvas-payments-paypal",
  "description": "PayPal Orders v2 REST API payment gateway integration for the Canvas PHP framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "info@quellabs.com"
    }
  ],
  "keywords": [
    "paypal",
    "paypal-rest",
    "paypal-orders",
    "payments",
    "payment gateway",
    "canvas",
    "canvas-payments"
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas-payments-paypal/issues",
    "forum": "https://github.com/quellabs/canvas-payments-paypal/discussions",
    "wiki": "https://github.com/quellabs/canvas-payments-paypal/wiki",
    "docs": "https://canvasphp.com/docs",
    "source": "https://github.com/quellabs/canvas-payments-paypal"
  },
  "require": {
    "php": "^8.2",
    "symfony/http-client": "^7.0 || ^8.0",
    "quellabs/support": "*",
    "quellabs/contracts": "*",
    "quellabs/canvas-payments-contracts": "*"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Payments\\Paypal\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "canvas": {
        "controller": "Quellabs\\Payments\\Paypal\\PaypalController"
      },
      "sculpt": {
        "provider": "Quellabs\\Payments\\Paypal\\ServiceProvider"
      },
      "payments": {
        "provider": "Quellabs\\Payments\\Paypal\\Driver",
        "config": "config/paypal.php"
      }
    }
  }
}
{
  "name": "quellabs/canvas-shipments-sendcloud",
  "description": "SendCloud shipping provider integration for the Canvas PHP framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "info@quellabs.com"
    }
  ],
  "keywords": [
    "sendcloud",
    "shipping",
    "shipment",
    "canvas",
    "canvas-shipments"
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas-shipments-sendcloud/issues",
    "forum": "https://github.com/quellabs/canvas-shipments-sendcloud/discussions",
    "wiki": "https://github.com/quellabs/canvas-shipments-sendcloud/wiki",
    "docs": "https://canvasphp.com/docs",
    "source": "https://github.com/quellabs/canvas-shipments-sendcloud"
  },
  "require": {
    "php": "^8.2",
    "symfony/http-client": "^7.0 || ^8.0",
    "quellabs/support": "*",
    "quellabs/contracts": "*",
    "quellabs/canvas-shipments-contracts": "*"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Shipments\\SendCloud\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "canvas": {
        "controller": "Quellabs\\Shipments\\SendCloud\\SendCloudController"
      },
      "sculpt": {
        "provider": "Quellabs\\Shipments\\SendCloud\\Sculpt\\ServiceProvider"
      },
      "shipments": {
        "provider": "Quellabs\\Shipments\\SendCloud\\Driver",
        "config": "config/sendcloud.php"
      }
    }
  }
}
{
  "name": "quellabs/canvas-shipments-dhl",
  "description": "DHL Parcel NL shipping provider integration for the Canvas PHP framework",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Floris van den Berg",
      "email": "info@quellabs.com"
    }
  ],
  "keywords": [
    "dhl",
    "shipping",
    "shipment",
    "canvas",
    "canvas-shipments"
  ],
  "support": {
    "email": "support@quellabs.com",
    "issues": "https://github.com/quellabs/canvas-shipments-dhl/issues",
    "forum": "https://github.com/quellabs/canvas-shipments-dhl/discussions",
    "wiki": "https://github.com/quellabs/canvas-shipments-dhl/wiki",
    "docs": "https://canvasphp.com/docs",
    "source": "https://github.com/quellabs/canvas-shipments-dhl"
  },
  "require": {
    "php": "^8.2",
    "symfony/http-client": "^7.0 || ^8.0",
    "quellabs/support": "*",
    "quellabs/contracts": "*",
    "quellabs/canvas-shipments-contracts": "*"
  },
  "autoload": {
    "psr-4": {
      "Quellabs\\Shipments\\DHL\\": "src/"
    }
  },
  "extra": {
    "discover": {
      "canvas": {
        "controller": "Quellabs\\Shipments\\DHL\\DHLController"
      },
      "sculpt": {
        "provider": "Quellabs\\Shipments\\DHL\\Sculpt\\ServiceProvider"
      },
      "shipments": {
        "provider": "Quellabs\\Shipments\\DHL\\Driver",
        "config": "config/dhl.php"
      }
    }
  }
}